/-
End-to-end checked-parse example.

This module intentionally owns its bytes instead of importing the per-structure
example fixtures. The fixture is a small ET_DYN ELF64 file with enough shape to
exercise cross-section coordination:

  * two PT_LOAD segments, including a writable segment whose `p_memsz` extends
    past `p_filesz`,
  * a PT_DYNAMIC table,
  * two DT_NEEDED entries plus DT_SONAME and DT_RUNPATH string references,
  * a four-entry `.dynsym` sized by DT_HASH.nchain,
  * both DT_RELA and DT_JMPREL relocation tables targeting the writable segment,
  * DT_INIT_ARRAY / DT_FINI_ARRAY call targets, including a zero no-op slot.

The bytes are not meant to be a runnable shared object; they are a valid
parser-visible ELF image for LeanLoad's checked parse stage.
-/

import LeanLoad.Parse

namespace LeanLoad.Parse.Examples

open LeanLoad.Parse

-- ---- Fixture coordinates ----------------------------------------------------

private def phnum : Nat := 3
private def phoff : Nat := ElfHeaderSize
private def phdrEnd : Nat := ElfHeaderSize + phnum * ProgramHeaderSize

private def entryEaddr : Nat := 0x100
private def finiEaddr : Nat := 0x108
private def dynamicOff : Nat := 0x120
private def dynamicEntryCount : Nat := 20
private def dynamicSize : Nat :=
  dynamicEntryCount * (Decodable.byteSize (α := RawEntry)).toNat

private def strtabOff : Nat := 0x280
private def strtabSize : Nat := 0x48
private def symCount : Nat := 4
private def symtabOff : Nat := 0x300
private def symtabSize : Nat :=
  symCount * (Decodable.byteSize (α := RawSym)).toNat
private def hashOff : Nat := 0x360
private def hashSize : Nat := 0x1c
private def relaOff : Nat := 0x380
private def jmprelOff : Nat := 0x398
private def initArrayOff : Nat := 0x3b0
private def finiArrayOff : Nat := 0x3c0

private def textFileSize : Nat := 0x400
private def textMemSize : Nat := 0x400
private def dataFileOff : Nat := textFileSize
private def dataEaddr : Nat := 0x1400
private def dataFileSize : Nat := 0x40
private def dataMemSize : Nat := 0x200
private def fileSize : Nat := dataFileOff + dataFileSize

#guard phdrEnd = 0xe8
#guard dynamicSize = 0x140
#guard strtabOff + strtabSize ≤ textFileSize
#guard symtabOff + symtabSize ≤ textFileSize
#guard hashOff + hashSize ≤ relaOff
#guard finiArrayOff + 8 ≤ textFileSize
#guard dataFileOff % 0x1000 = dataEaddr % 0x1000

private def eaddrOfNat (n : Nat) : Eaddr :=
  ⟨n.toUInt64⟩

private def fileOffOfNat (n : Nat) : FileOff :=
  ⟨n.toUInt64⟩

-- ---- Whole-file image -------------------------------------------------------

/--
One self-contained ELF byte image.

All multi-byte scalars are little-endian. The right-hand offsets are file
offsets, while comments name the ELF field/value that the checked parser will
decode. Keeping the bytes literal makes this an end-to-end parse fixture; the
comments are the map that keeps the literal auditable.
-/
def fixtureBytes : ByteArray := ⟨#[
  -- Elf64_Ehdr, gabi 04 "ELF Header". The header is the first 64 bytes.
  0x7f, 0x45, 0x4c, 0x46, 0x02, 0x01, 0x01, 0x00, -- 0x0000: e_ident = magic, ELFCLASS64, ELFDATA2LSB, EV_CURRENT, SYSV ABI
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0008: e_ident ABI version 0, then padding
  0x03, 0x00, 0x3e, 0x00, 0x01, 0x00, 0x00, 0x00, -- 0x0010: e_type = ET_DYN, e_machine = EM_X86_64, e_version = EV_CURRENT
  0x00, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0018: e_entry = 0x100, inside the executable PT_LOAD
  0x40, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0020: e_phoff = 0x40, program headers start immediately after Elf64_Ehdr
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0028: e_shoff = 0, no section-header table
  0x00, 0x00, 0x00, 0x00, 0x40, 0x00, 0x38, 0x00, -- 0x0030: e_flags = 0, e_ehsize = 64, e_phentsize = 56
  0x03, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0038: e_phnum = 3, no section headers, SHN_UNDEF shstrndx

  -- Program header #0, gabi 07 "Program Header": executable file-backed PT_LOAD.
  -- It identity-maps file offsets 0x0..0x3ff to eaddrs 0x0..0x3ff so dynamic
  -- pointers such as DT_STRTAB = 0x280 resolve directly to file offsets.
  0x01, 0x00, 0x00, 0x00, 0x05, 0x00, 0x00, 0x00, -- 0x0040: p_type = PT_LOAD, p_flags = PF_R | PF_X
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0048: p_offset = 0
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0050: p_vaddr = 0
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0058: p_paddr = 0, ignored but mirrored to p_vaddr
  0x00, 0x04, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0060: p_filesz = 0x400, covers all metadata below
  0x00, 0x04, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0068: p_memsz = 0x400, no BSS in the executable segment
  0x00, 0x10, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0070: p_align = 0x1000, page congruent with p_offset/p_vaddr

  -- Program header #1: writable PT_LOAD at a non-identity file/eaddr mapping.
  -- p_memsz > p_filesz creates a BSS tail after the 0x40 file-backed bytes.
  0x01, 0x00, 0x00, 0x00, 0x06, 0x00, 0x00, 0x00, -- 0x0078: p_type = PT_LOAD, p_flags = PF_R | PF_W
  0x00, 0x04, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0080: p_offset = 0x400
  0x00, 0x14, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0088: p_vaddr = 0x1400
  0x00, 0x14, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0090: p_paddr = 0x1400, ignored but mirrored to p_vaddr
  0x40, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0098: p_filesz = 0x40, file bytes at 0x400..0x43f
  0x00, 0x02, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x00a0: p_memsz = 0x200, BSS continues through eaddr 0x15ff
  0x00, 0x10, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x00a8: p_align = 0x1000, 0x400 % 0x1000 = 0x1400 % 0x1000

  -- Program header #2: PT_DYNAMIC names the dynamic table inside PT_LOAD #0.
  0x02, 0x00, 0x00, 0x00, 0x04, 0x00, 0x00, 0x00, -- 0x00b0: p_type = PT_DYNAMIC, p_flags = PF_R
  0x20, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x00b8: p_offset = 0x120
  0x20, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x00c0: p_vaddr = 0x120
  0x20, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x00c8: p_paddr = 0x120, ignored but mirrored to p_vaddr
  0x40, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x00d0: p_filesz = 0x140, exactly 20 Elf64_Dyn entries
  0x40, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x00d8: p_memsz = 0x140
  0x08, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x00e0: p_align = 8 for 64-bit dynamic entries

  -- 0x00e8..0x00ff: padding from the phdr table to the entry code at 0x100.
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,

  -- Tiny executable region. 0xc3 is RET; 0xcc is INT3 padding. The parser only
  -- checks that e_entry and array call targets land in an executable segment.
  0xc3, 0xcc, 0xcc, 0xcc, 0xcc, 0xcc, 0xcc, 0xcc, -- 0x0100: entry target, then padding
  0xc3, 0xcc, 0xcc, 0xcc, 0xcc, 0xcc, 0xcc, 0xcc, -- 0x0108: fini target, then padding
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0110..0x0117: padding before .dynamic
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0118..0x011f: padding before .dynamic

  -- Elf64_Dyn table, gabi 08 "Dynamic Section". Each entry is d_tag, then d_un.
  -- String-valued tags use offsets into .dynstr; address-valued tags are eaddrs
  -- resolved through the checked PT_LOAD table.
  0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0120: d_tag = DT_NEEDED
  0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0128: d_val = 0x01 -> "libc.so.6"
  0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0130: d_tag = DT_NEEDED
  0x0b, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0138: d_val = 0x0b -> "libm.so.6"
  0x0e, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0140: d_tag = DT_SONAME
  0x2e, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0148: d_val = 0x2e -> "fixture.so"
  0x1d, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0150: d_tag = DT_RUNPATH
  0x39, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0158: d_val = 0x39 -> "$ORIGIN/lib"
  0x05, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0160: d_tag = DT_STRTAB
  0x80, 0x02, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0168: d_ptr = 0x280, identity-mapped to file offset 0x280
  0x0a, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0170: d_tag = DT_STRSZ
  0x48, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0178: d_val = 0x48 bytes
  0x06, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0180: d_tag = DT_SYMTAB
  0x00, 0x03, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0188: d_ptr = 0x300, identity-mapped to file offset 0x300
  0x0b, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0190: d_tag = DT_SYMENT
  0x18, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0198: d_val = 24, sizeof Elf64_Sym
  0x04, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x01a0: d_tag = DT_HASH
  0x60, 0x03, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x01a8: d_ptr = 0x360, SysV hash with nchain = 4 symbols
  0x07, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x01b0: d_tag = DT_RELA
  0x80, 0x03, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x01b8: d_ptr = 0x380, one non-PLT Rela entry
  0x08, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x01c0: d_tag = DT_RELASZ
  0x18, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x01c8: d_val = 24 bytes, one Elf64_Rela
  0x09, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x01d0: d_tag = DT_RELAENT
  0x18, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x01d8: d_val = 24, sizeof Elf64_Rela
  0x17, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x01e0: d_tag = DT_JMPREL
  0x98, 0x03, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x01e8: d_ptr = 0x398, one PLT-style Rela entry
  0x02, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x01f0: d_tag = DT_PLTRELSZ
  0x18, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x01f8: d_val = 24 bytes, one Elf64_Rela
  0x14, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0200: d_tag = DT_PLTREL
  0x07, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0208: d_val = DT_RELA, so JMPREL entries are Elf64_Rela
  0x19, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0210: d_tag = DT_INIT_ARRAY
  0xb0, 0x03, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0218: d_ptr = 0x3b0, two u64 call-target slots
  0x1b, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0220: d_tag = DT_INIT_ARRAYSZ
  0x10, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0228: d_val = 16 bytes
  0x1a, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0230: d_tag = DT_FINI_ARRAY
  0xc0, 0x03, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0238: d_ptr = 0x3c0, one u64 call-target slot
  0x1c, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0240: d_tag = DT_FINI_ARRAYSZ
  0x08, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0248: d_val = 8 bytes
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0250: d_tag = DT_NULL, terminates the dynamic array
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0258: d_un = 0 for DT_NULL

  -- 0x0260..0x027f: padding from the dynamic table to .dynstr at 0x280.
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,

  -- .dynstr. Dynamic tags and symbols reference these by byte offset from 0x280.
  0x00,                                                       -- 0x0280 [0x00]: ""
  0x6c, 0x69, 0x62, 0x63, 0x2e, 0x73, 0x6f, 0x2e, 0x36, 0x00, -- [0x01]: "libc.so.6\0"
  0x6c, 0x69, 0x62, 0x6d, 0x2e, 0x73, 0x6f, 0x2e, 0x36, 0x00, -- [0x0b]: "libm.so.6\0"
  0x70, 0x75, 0x74, 0x73, 0x00,                               -- [0x15]: "puts\0"
  0x65, 0x78, 0x70, 0x6f, 0x72, 0x74, 0x65, 0x64, 0x00,         -- [0x1a]: "exported\0"
  0x77, 0x65, 0x61, 0x6b, 0x5f, 0x75, 0x6e, 0x64, 0x65, 0x66, 0x00, -- [0x23]: "weak_undef\0"
  0x66, 0x69, 0x78, 0x74, 0x75, 0x72, 0x65, 0x2e, 0x73, 0x6f, 0x00, -- [0x2e]: "fixture.so\0"
  0x24, 0x4f, 0x52, 0x49, 0x47, 0x49, 0x4e, 0x2f, 0x6c, 0x69, 0x62, 0x00, -- [0x39]: "$ORIGIN/lib\0"
  0x00, 0x00, 0x00,                                           -- 0x02c5..0x02c7: padding to DT_STRSZ = 0x48

  -- 0x02c8..0x02ff: padding from the end of .dynstr to .dynsym at 0x300.
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,

  -- .dynsym, gabi 05 "Symbol Table". DT_HASH.nchain says there are 4 entries.
  -- Symbol #0: required undefined/null symbol.
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0300: st_name = 0, info/other = 0, st_shndx = SHN_UNDEF
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0308: st_value = 0
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0310: st_size = 0
  -- Symbol #1: global undefined function "puts".
  0x15, 0x00, 0x00, 0x00, 0x12, 0x00, 0x00, 0x00, -- 0x0318: st_name = 0x15, info = GLOBAL|FUNC, SHN_UNDEF
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0320: st_value = 0
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0328: st_size = 0
  -- Symbol #2: global defined function "exported" at executable eaddr 0x100.
  0x1a, 0x00, 0x00, 0x00, 0x12, 0x00, 0x01, 0x00, -- 0x0330: st_name = 0x1a, info = GLOBAL|FUNC, st_shndx = 1
  0x00, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0338: st_value = 0x100
  0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0340: st_size = 1
  -- Symbol #3: weak undefined "weak_undef" to exercise weak-undef classification.
  0x23, 0x00, 0x00, 0x00, 0x20, 0x00, 0x00, 0x00, -- 0x0348: st_name = 0x23, info = WEAK|NOTYPE, SHN_UNDEF
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0350: st_value = 0
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0358: st_size = 0

  -- SysV DT_HASH header. LeanLoad reads nchain to size .dynsym deterministically.
  0x01, 0x00, 0x00, 0x00, -- 0x0360: nbucket = 1
  0x04, 0x00, 0x00, 0x00, -- 0x0364: nchain = 4
  0x01, 0x00, 0x00, 0x00, -- 0x0368: bucket[0] = 1
  0x00, 0x00, 0x00, 0x00, -- 0x036c: chain[0] = 0
  0x02, 0x00, 0x00, 0x00, -- 0x0370: chain[1] = 2
  0x00, 0x00, 0x00, 0x00, -- 0x0374: chain[2] = 0
  0x00, 0x00, 0x00, 0x00, -- 0x0378: chain[3] = 0
  0x00, 0x00, 0x00, 0x00, -- 0x037c..0x037f: padding before DT_RELA

  -- DT_RELA table: one non-PLT relocation targeting the writable PT_LOAD.
  0x10, 0x14, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0380: r_offset = 0x1410, inside writable segment
  0x08, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0388: r_info = type 8, symbol index 0
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0390: r_addend = 0

  -- DT_JMPREL table: one PLT relocation, also targeting the writable PT_LOAD.
  0x20, 0x14, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0398: r_offset = 0x1420, inside writable segment
  0x06, 0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, -- 0x03a0: r_info = type 6, symbol index 1 ("puts")
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x03a8: r_addend = 0

  -- Init/fini arrays. A zero init-array slot is accepted as a no-op call target.
  0x00, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x03b0: init[0] = 0x100, executable entry target
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x03b8: init[1] = 0, ABI no-op slot
  0x08, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x03c0: fini[0] = 0x108, executable fini target

  -- 0x03c8..0x03ff: padding out PT_LOAD #0 to p_filesz = 0x400.
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,

  -- PT_LOAD #1 file bytes, mapped from file offset 0x400 to eaddr 0x1400.
  0xde, 0xad, 0xbe, 0xef, -- 0x0400: visible payload at eaddr 0x1400
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, -- 0x0404..0x040f: file-backed writable bytes
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0410..0x041f: relocation target window
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, -- 0x0420..0x042f: JMPREL target window
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 -- 0x0430..0x043f: final file bytes; BSS continues to 0x15ff
]⟩

-- ---- Raw byte anchors -------------------------------------------------------

private def hasByte (off : Nat) (b : UInt8) : Bool :=
  fixtureBytes[off]? == some b

#guard fixtureBytes.size == fileSize
#guard hasByte entryEaddr 0xc3          -- e_entry lands on executable code
#guard hasByte dynamicOff 0x01          -- first dynamic tag is DT_NEEDED
#guard hasByte (strtabOff + 1) 0x6c     -- first DT_NEEDED starts with 'l'
#guard hasByte (symtabOff + 0x30) 0x1a  -- "exported" symbol's st_name
#guard hasByte relaOff 0x10             -- DT_RELA r_offset = 0x1410
#guard hasByte dataFileOff 0xde         -- second PT_LOAD starts at file offset 0x400

/-- Pure counterpart to production parsing over the standalone fixture. -/
def fixture : Except String Elf :=
  parseByteArray fixtureBytes

-- ---- End-to-end checked parse facts -----------------------------------------

private def parsed? : Option Elf :=
  fixture.toOption

-- Machine and dynamic strings.
private def parsedFileSize? : Option Nat :=
  parsed?.map (fun elf => elf.fileSize.toNat)

private def parsedMachine? : Option ElfMachine :=
  parsed?.map (fun elf => elf.machine)

private def parsedNeeded? :=
  parsed?.map (fun elf => elf.needed)

private def parsedSoname? : Option String :=
  parsed?.bind (fun elf => elf.soname)

private def parsedRunpath? : Option String :=
  parsed?.bind (fun elf => elf.runpath)

-- PT_LOAD table.
private def segmentCount? : Option Nat :=
  parsed?.map (fun elf => elf.segments.items.size)

private def segmentField? (idx : Nat)
    (f : {fileSize : ByteSize} → Segment fileSize → α) : Option α :=
  parsed?.bind (fun elf => (elf.segments.items[idx]?).map (fun segment => f segment))

private def textSegmentEaddr? : Option Eaddr :=
  segmentField? 0 (fun s => s.eaddr)

private def textSegmentOffset? : Option FileOff :=
  segmentField? 0 (fun s => s.offset)

private def textSegmentFileSize? : Option Nat :=
  segmentField? 0 (fun s => s.filesz.toNat)

private def textSegmentMemSize? : Option Nat :=
  segmentField? 0 (fun s => s.memsz.toNat)

private def textSegmentExec? : Option Bool :=
  segmentField? 0 (fun s => s.perm.exec)

private def textSegmentWrite? : Option Bool :=
  segmentField? 0 (fun s => s.perm.write)

private def dataSegmentEaddr? : Option Eaddr :=
  segmentField? 1 (fun s => s.eaddr)

private def dataSegmentOffset? : Option FileOff :=
  segmentField? 1 (fun s => s.offset)

private def dataSegmentFileSize? : Option Nat :=
  segmentField? 1 (fun s => s.filesz.toNat)

private def dataSegmentMemSize? : Option Nat :=
  segmentField? 1 (fun s => s.memsz.toNat)

private def dataSegmentWrite? : Option Bool :=
  segmentField? 1 (fun s => s.perm.write)

private def dataSegmentExec? : Option Bool :=
  segmentField? 1 (fun s => s.perm.exec)

-- Dynamic symbol table.
private def parsedSymtabSize? : Option Nat :=
  parsed?.map (fun elf => elf.symtab.size)

private def nullSym? :=
  parsed?.bind (fun elf => elf.symtab[0]?)

private def putsSym? :=
  parsed?.bind (fun elf => elf.symtab[1]?)

private def exportedSym? :=
  parsed?.bind (fun elf => elf.symtab[2]?)

private def weakUndefSym? :=
  parsed?.bind (fun elf => elf.symtab[3]?)

private def nullSymName? : Option String :=
  nullSym?.map (fun s => s.name)

private def nullSymUndef? : Option Bool :=
  nullSym?.map (fun s => s.isUndef)

private def putsSymName? : Option String :=
  putsSym?.map (fun s => s.name)

private def putsSymUndef? : Option Bool :=
  putsSym?.map (fun s => s.isUndef)

private def putsSymWeak? : Option Bool :=
  putsSym?.map (fun s => s.isWeak)

private def exportedSymName? : Option String :=
  exportedSym?.map (fun s => s.name)

private def exportedSymGlobalDef? : Option Bool :=
  exportedSym?.map (fun s => s.isGlobalDef)

private def exportedSymValue? : Option Nat :=
  exportedSym?.map (fun s => s.value.toNat)

private def weakUndefSymName? : Option String :=
  weakUndefSym?.map (fun s => s.name)

private def weakUndefSymUndef? : Option Bool :=
  weakUndefSym?.map (fun s => s.isUndef)

private def weakUndefSymWeak? : Option Bool :=
  weakUndefSym?.map (fun s => s.isWeak)

-- Relocations and call targets.
private def dataRelaCount? : Option Nat :=
  parsed?.bind (fun elf =>
    if h : 1 < elf.segments.items.size then
      some ((elf.relocs.relaFor ⟨1, h⟩).size)
    else
      none)

private def dataJmprelCount? : Option Nat :=
  parsed?.bind (fun elf =>
    if h : 1 < elf.segments.items.size then
      some ((elf.relocs.jmprelFor ⟨1, h⟩).size)
    else
      none)

private def entryTarget? :=
  parsed?.map (fun elf => elf.callTargets.entry.val)

private def initTargetCount? : Option Nat :=
  parsed?.map (fun elf => elf.callTargets.init.size)

private def initTargetEaddr? (idx : Nat) : Option Eaddr :=
  parsed?.bind (fun elf => (elf.callTargets.init[idx]?).map (fun target => target.val))

private def initTarget0Eaddr? : Option Eaddr :=
  initTargetEaddr? 0

private def initTarget1Eaddr? : Option Eaddr :=
  initTargetEaddr? 1

private def finiTargetCount? : Option Nat :=
  parsed?.map (fun elf => elf.callTargets.fini.size)

private def finiTargetEaddr? (idx : Nat) : Option Eaddr :=
  parsed?.bind (fun elf => (elf.callTargets.fini[idx]?).map (fun target => target.val))

private def finiTarget0Eaddr? : Option Eaddr :=
  finiTargetEaddr? 0

-- Machine and dynamic strings.
#guard parsedFileSize? == some fileSize
#guard parsedMachine? == some .x86_64
#guard parsedNeeded? == some #["libc.so.6", "libm.so.6"]
#guard parsedSoname? == some "fixture.so"
#guard parsedRunpath? == some "$ORIGIN/lib"

-- PT_LOAD table.
#guard segmentCount? == some 2
#guard textSegmentEaddr? == some (eaddrOfNat 0)
#guard textSegmentOffset? == some (fileOffOfNat 0)
#guard textSegmentFileSize? == some textFileSize
#guard textSegmentMemSize? == some textMemSize
#guard textSegmentExec? == some true
#guard textSegmentWrite? == some false
#guard dataSegmentEaddr? == some (eaddrOfNat dataEaddr)
#guard dataSegmentOffset? == some (fileOffOfNat dataFileOff)
#guard dataSegmentFileSize? == some dataFileSize
#guard dataSegmentMemSize? == some dataMemSize
#guard dataSegmentWrite? == some true
#guard dataSegmentExec? == some false

-- Dynamic symbol table.
#guard parsedSymtabSize? == some symCount
#guard nullSymName? == some ""
#guard nullSymUndef? == some true
#guard putsSymName? == some "puts"
#guard putsSymUndef? == some true
#guard putsSymWeak? == some false
#guard exportedSymName? == some "exported"
#guard exportedSymGlobalDef? == some true
#guard exportedSymValue? == some entryEaddr
#guard weakUndefSymName? == some "weak_undef"
#guard weakUndefSymUndef? == some true
#guard weakUndefSymWeak? == some true

-- Relocations and call targets.
#guard dataRelaCount? == some 1
#guard dataJmprelCount? == some 1
#guard entryTarget? == some (eaddrOfNat entryEaddr)
#guard initTargetCount? == some 2
#guard initTarget0Eaddr? == some (eaddrOfNat entryEaddr)
#guard initTarget1Eaddr? == some (eaddrOfNat 0)
#guard finiTargetCount? == some 1
#guard finiTarget0Eaddr? == some (eaddrOfNat finiEaddr)

end LeanLoad.Parse.Examples
